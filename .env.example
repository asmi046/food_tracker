MAX_BOT_TOKEN=
NODE_ENV=development

# MySQL connection (Prisma format)
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=mysql://root:@127.0.0.1:3306/food_tracker

# User access control
# Пользователь с этим MAX user id всегда имеет доступ без ручной верификации.
ADMIN_MAX_USER_ID=

# AI provider settings
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=
# Модель по умолчанию. Список моделей: https://openrouter.ai/models
# Поддерживает vision (распознавание изображений):
# google/gemini-2.0-flash-lite  — быстрая и дешевая
# google/gemini-2.5-pro-exp     — более точная
# openai/gpt-4o-mini            — хорошая точность
OPENROUTER_MODEL=google/gemini-2.0-flash-lite

# OpenAI provider settings
# Чтобы переключиться на OpenAI, установи AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
